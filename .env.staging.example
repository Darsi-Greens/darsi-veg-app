# Staging environment template — copy to .env.staging and fill values
# Firebase project: darsi-veg-staging (create at https://console.firebase.google.com)

APP_ENV=staging
EXPO_PUBLIC_APP_ENV=staging
EXPO_PUBLIC_APP_NAME=NRB Veg QA

EXPO_PUBLIC_FIREBASE_API_KEY=your_staging_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=darsi-veg-staging.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=darsi-veg-staging
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=darsi-veg-staging.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_staging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_staging_app_id

EXPO_PUBLIC_APP_PIN=1234
