{
  "cli": {
    "version": ">= 13.0.0"
  },
  "build": {
    "development": {
      "distribution": "internal",
      "env": {
        "APP_ENV": "development"
      },
      "android": {
        "buildType": "apk",
        "packageName": "com.nrbveg.dev"
      }
    },
    "staging": {
      "distribution": "internal",
      "env": {
        "APP_ENV": "staging"
      },
      "android": {
        "buildType": "apk",
        "packageName": "com.nrbveg.staging"
      }
    },
    "production": {
      "distribution": "internal",
      "env": {
        "APP_ENV": "production"
      },
      "android": {
        "buildType": "apk",
        "packageName": "com.nrbveg.app"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "../darsi-veg-backend/serviceAccountKey.json",
        "track": "internal"
      }
    }
  }
}
