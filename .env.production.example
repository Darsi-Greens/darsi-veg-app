# Production environment template — copy to .env.production and fill values
# Firebase project: darsi-veg-shop (the live project with real parent data)

APP_ENV=production
EXPO_PUBLIC_APP_ENV=production
EXPO_PUBLIC_APP_NAME=NRB Vegetables

EXPO_PUBLIC_FIREBASE_API_KEY=your_production_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=darsi-veg-shop.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=darsi-veg-shop
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=darsi-veg-shop.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_production_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_production_app_id

EXPO_PUBLIC_APP_PIN=your_actual_shop_pin
